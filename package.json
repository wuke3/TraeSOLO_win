{
  "name": "trae-solo-win",
  "version": "1.0.0",
  "description": "TRAE SOLO Win",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:linux": "electron-builder --linux deb appimage snap --publish never"
  },
  "keywords": [
    "electron",
    "trae",
    "solo"
  ],
  "author": {
    "name": "TRAE",
    "email": "contact@trae.ai"
  },
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.trae.solo-win",
    "productName": "TRAE SOLO Win",
    "icon": "src/favicon.png",
    "target": [
      "exe",
      "nsis",
      "deb",
      "appimage",
      "snap"
    ],
    "win": {
      "icon": "src/favicon.png"
    },
    "linux": {
      "icon": "src/favicon.png"
    }
  }
}